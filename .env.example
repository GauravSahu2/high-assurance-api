# ── Environment Template ──────────────────────────────────────────────────────
# Copy this to .env and fill in real values before running docker compose.
# NEVER commit .env to version control.

# Database
POSTGRES_USER=admin
POSTGRES_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD
POSTGRES_DB=high_assurance

# Redis
REDIS_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD

# JWT (generate with: python -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET=CHANGE_ME_GENERATE_WITH_SECRETS_TOKEN_HEX

# Grafana
GRAFANA_PASSWORD=admin

# Deployment
DEPLOY_ENV=development

# OpenTelemetry (optional — leave empty for console-only)
OTEL_ENDPOINT=
