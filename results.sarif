{"$schema": "https://raw.githubusercontent.com/oasis-tcs/sarif-spec/main/sarif-2.1/schema/sarif-schema-2.1.0.json", "version": "2.1.0", "runs": [{"tool": {"driver": {"name": "Checkov", "version": "3.2.521", "informationUri": "https://checkov.io", "rules": [{"id": "CKV_K8S_43", "name": "Image should use digest", "shortDescription": {"text": "Image should use digest"}, "fullDescription": {"text": "Image should use digest"}, "help": {"text": "Image should use digest\nResource: Deployment.high-assurance.high-assurance-api"}, "defaultConfiguration": {"level": "error"}, "helpUri": "https://docs.prismacloud.io/en/enterprise-edition/policy-reference/kubernetes-policies/kubernetes-policy-index/bc-k8s-39"}, {"id": "CKV_K8S_35", "name": "Prefer using secrets as files over secrets as environment variables", "shortDescription": {"text": "Prefer using secrets as files over secrets as environment variables"}, "fullDescription": {"text": "Prefer using secrets as files over secrets as environment variables"}, "help": {"text": "Prefer using secrets as files over secrets as environment variables\nResource: Deployment.high-assurance.high-assurance-api"}, "defaultConfiguration": {"level": "error"}, "helpUri": "https://docs.prismacloud.io/en/enterprise-edition/policy-reference/kubernetes-policies/kubernetes-policy-index/bc-k8s-33"}], "organization": "bridgecrew"}}, "results": [{"ruleId": "CKV_K8S_43", "ruleIndex": 0, "level": "error", "attachments": [], "message": {"text": "Image should use digest"}, "locations": [{"physicalLocation": {"artifactLocation": {"uri": "k8s/k8s/deployment.yaml"}, "region": {"startLine": 1, "endLine": 106, "snippet": {"text": "apiVersion: apps/v1\nkind: Deployment\nmetadata:\n  name: high-assurance-api\n  namespace: high-assurance\n  annotations:\n    checkov.io/skip: \"CKV_K8S_35=Application requires 12-factor env vars\"\n  labels:\n    app: high-assurance-api\n    tier: backend\n    compliance: pci-dss\nspec:\n  replicas: 3\n  selector:\n    matchLabels:\n      app: high-assurance-api\n  strategy:\n    type: RollingUpdate\n    rollingUpdate:\n      maxUnavailable: 1\n      maxSurge: 1\n  template:\n    metadata:\n      labels:\n        app: high-assurance-api\n      annotations:\n        prometheus.io/scrape: \"true\"\n        prometheus.io/port: \"5000\"\n        prometheus.io/path: \"/metrics\"\n        checkov.io/skip1: \"CKV_K8S_35=Application requires 12-factor env vars\"\n    spec:\n      automountServiceAccountToken: false\n      securityContext:\n        runAsNonRoot: true\n        runAsUser: 10001\n        runAsGroup: 10001\n        fsGroup: 10001\n        seccompProfile:\n          type: RuntimeDefault\n      containers:\n        - name: api\n          image: ghcr.io/GauravSahu2/high-assurance-api:81de515\n          imagePullPolicy: Always\n          securityContext:\n            allowPrivilegeEscalation: false\n            readOnlyRootFilesystem: true\n            runAsNonRoot: true\n            capabilities:\n              drop:\n                - ALL\n          ports:\n            - containerPort: 5000\n              protocol: TCP\n          env:\n            - name: DATABASE_URL\n              valueFrom:\n                secretKeyRef:\n                  name: hsa-secrets\n                  key: database-url\n            - name: JWT_SECRET\n              valueFrom:\n                secretKeyRef:\n                  name: hsa-secrets\n                  key: jwt-secret\n            - name: REDIS_URL\n              valueFrom:\n                secretKeyRef:\n                  name: hsa-secrets\n                  key: redis-url\n            - name: DEPLOY_ENV\n              value: \"production\"\n            - name: OTEL_EXPORTER_OTLP_ENDPOINT\n              value: \"http://otel-collector:4317\"\n          resources:\n            requests:\n              cpu: 250m\n              memory: 256Mi\n            limits:\n              cpu: 1000m\n              memory: 512Mi\n          readinessProbe:\n            httpGet:\n              path: /health\n              port: 5000\n            initialDelaySeconds: 5\n            periodSeconds: 10\n            timeoutSeconds: 3\n            failureThreshold: 3\n            successThreshold: 1\n          livenessProbe:\n            httpGet:\n              path: /\n              port: 5000\n            initialDelaySeconds: 10\n            periodSeconds: 15\n            timeoutSeconds: 3\n            failureThreshold: 3\n          startupProbe:\n            httpGet:\n              path: /health\n              port: 5000\n            initialDelaySeconds: 3\n            periodSeconds: 5\n            failureThreshold: 12\n      terminationGracePeriodSeconds: 30\n---\n"}}}}]}, {"ruleId": "CKV_K8S_35", "ruleIndex": 1, "level": "warning", "attachments": [], "message": {"text": "Prefer using secrets as files over secrets as environment variables"}, "locations": [{"physicalLocation": {"artifactLocation": {"uri": "k8s/k8s/deployment.yaml"}, "region": {"startLine": 1, "endLine": 106, "snippet": {"text": "apiVersion: apps/v1\nkind: Deployment\nmetadata:\n  name: high-assurance-api\n  namespace: high-assurance\n  annotations:\n    checkov.io/skip: \"CKV_K8S_35=Application requires 12-factor env vars\"\n  labels:\n    app: high-assurance-api\n    tier: backend\n    compliance: pci-dss\nspec:\n  replicas: 3\n  selector:\n    matchLabels:\n      app: high-assurance-api\n  strategy:\n    type: RollingUpdate\n    rollingUpdate:\n      maxUnavailable: 1\n      maxSurge: 1\n  template:\n    metadata:\n      labels:\n        app: high-assurance-api\n      annotations:\n        prometheus.io/scrape: \"true\"\n        prometheus.io/port: \"5000\"\n        prometheus.io/path: \"/metrics\"\n        checkov.io/skip1: \"CKV_K8S_35=Application requires 12-factor env vars\"\n    spec:\n      automountServiceAccountToken: false\n      securityContext:\n        runAsNonRoot: true\n        runAsUser: 10001\n        runAsGroup: 10001\n        fsGroup: 10001\n        secc